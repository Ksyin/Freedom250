<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Freedom 250 | Event Engagement Platform</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    :root {
      --navy: #16254c;
      --navy-dark: #0b1633;
      --red: #b22234;
      --red-dark: #8f1b2a;
      --blue: #2f4f9f;
      --ink: #172033;
      --muted: #64748b;
      --line: #dbe3ef;
      --paper: #f6f8fc;
      --white: #ffffff;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      min-height: 100vh;
      font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--ink);
      background: var(--paper);
    }

    .flag-strip { height: 5px; background: linear-gradient(90deg, var(--red) 0 33%, var(--white) 33% 66%, var(--blue) 66% 100%); }
    .shell { max-width: 1180px; margin: 0 auto; padding: 0 20px; }
    .card {
      background: var(--white);
      border: 1px solid var(--line);
      border-radius: 8px;
      box-shadow: 0 14px 34px rgba(20, 34, 67, 0.08);
    }
    .soft-card {
      background: #ffffff;
      border: 1px solid #e1e8f4;
      border-radius: 8px;
    }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      border-radius: 6px;
      padding: 11px 16px;
      font-weight: 800;
      line-height: 1;
      transition: transform .15s ease, background .15s ease, border .15s ease;
      white-space: nowrap;
    }
    .btn:hover { transform: translateY(-1px); }
    .btn-primary { color: white; background: var(--red); }
    .btn-primary:hover { background: var(--red-dark); }
    .btn-secondary { color: white; background: var(--navy); }
    .btn-secondary:hover { background: var(--navy-dark); }
    .btn-outline { color: var(--navy); background: white; border: 1px solid #b7c4d8; }
    .btn-outline:hover { border-color: var(--navy); background: #f8fafc; }
    .stat { border-left: 4px solid var(--red); }
    .nav-link.active { color: var(--red); }
    .route-panel { display: none; }
    .route-panel.active { display: block; }
    .pill {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      border-radius: 999px;
      padding: 6px 10px;
      font-size: 12px;
      font-weight: 800;
      color: var(--navy);
      background: #eef3fb;
      border: 1px solid #d5e0ef;
    }
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; }
    td, th { border-bottom: 1px solid #e7edf6; padding: 10px 8px; text-align: left; font-size: 13px; }
    th { color: var(--muted); font-size: 12px; text-transform: uppercase; letter-spacing: .04em; }
    input, select, textarea {
      width: 100%;
      border: 1px solid #cbd5e1;
      border-radius: 6px;
      padding: 10px 12px;
      background: white;
      color: var(--ink);
      outline: none;
    }
    input:focus, select:focus, textarea:focus { border-color: var(--blue); box-shadow: 0 0 0 3px rgba(47, 79, 159, .12); }
    .mobile-menu { display: none; }

    @media (max-width: 820px) {
      .desktop-nav { display: none; }
      .mobile-menu.open { display: grid; }
      .hero-grid { grid-template-columns: 1fr !important; }
      .dashboard-grid { grid-template-columns: 1fr !important; }
      .btn { width: 100%; }
      .mobile-stack { flex-direction: column; align-items: stretch !important; }
    }
  </style>
</head>
<body>
  <div class="flag-strip"></div>

  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-slate-200">
    <div class="shell flex items-center justify-between py-3">
      <button class="flex items-center gap-3 text-left" data-route="/">
        <div class="h-11 w-11 rounded-md bg-[#16254c] text-white grid place-items-center font-black">250</div>
        <div>
          <div class="font-black text-xl tracking-tight text-[#16254c]">Freedom 250</div>
          <div class="text-xs font-bold text-slate-500">Event Engagement System</div>
        </div>
      </button>

      <nav class="desktop-nav flex items-center gap-6 text-sm font-bold text-slate-600">
        <a href="#mission" class="hover:text-[#b22234]">Mission</a>
        <a href="#events" class="hover:text-[#b22234]">Events</a>
        <a href="#timeline" class="hover:text-[#b22234]">Timeline</a>
        <button class="nav-link hover:text-[#b22234]" data-route="/volunteer">Volunteer</button>
        <button class="nav-link hover:text-[#b22234]" data-route="/booth-admin">Booth Admin</button>
        <button class="nav-link hover:text-[#b22234]" data-route="/admin">Super Admin</button>
      </nav>

      <div class="flex items-center gap-2">
        <button class="btn btn-primary hidden sm:inline-flex" data-route="/"><i class="fa-solid fa-passport"></i> Get Liberty Pass</button>
        <button id="menuBtn" class="btn btn-outline sm:hidden" aria-label="Open menu"><i class="fa-solid fa-bars"></i></button>
      </div>
    </div>
    <div id="mobileMenu" class="mobile-menu shell pb-4 gap-2 text-sm font-bold">
      <button class="btn btn-outline" data-route="/">Participant Pass</button>
      <button class="btn btn-outline" data-route="/volunteer">Volunteer</button>
      <button class="btn btn-outline" data-route="/booth-admin">Booth Admin</button>
      <button class="btn btn-outline" data-route="/admin">Super Admin</button>
      <button class="btn btn-outline" data-route="/organizer">Organizer</button>
    </div>
  </header>

  <main>
    <section id="participantView" class="route-panel active">
      <section class="bg-white border-b border-slate-200">
        <div class="shell grid hero-grid grid-cols-[1.1fr_.9fr] gap-10 items-center py-14 md:py-20">
          <div>
            <span class="pill"><i class="fa-solid fa-location-dot text-[#b22234]"></i> JKUAT Main Campus | June 11-12, 2026</span>
            <h1 class="mt-5 text-4xl md:text-6xl font-black leading-tight text-[#16254c]">Freedom 250 is a digital event passport for an interactive US-Kenya innovation festival.</h1>
            <p class="mt-5 text-lg text-slate-600 max-w-2xl">Participants collect booth stamps, complete missions, earn Freedom Coins, redeem rewards, and move through event zones with a QR-based Liberty Pass.</p>
            <div class="mt-7 flex flex-wrap gap-3 mobile-stack">
              <button class="btn btn-primary" id="openPassBtn"><i class="fa-solid fa-passport"></i> Get Liberty Pass</button>
              <a class="btn btn-outline" href="#events"><i class="fa-solid fa-calendar-days"></i> View Event Zones</a>
            </div>
          </div>
          <div class="card p-5">
            <div class="rounded-md overflow-hidden border border-slate-200">
              <img alt="Freedom 250 event participants" class="w-full h-64 object-cover" src="https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=900&h=600&fit=crop">
            </div>
            <div class="grid grid-cols-3 gap-3 mt-4">
              <div class="soft-card p-3 text-center"><div class="text-2xl font-black text-[#b22234]">8</div><div class="text-xs font-bold text-slate-500">Zones</div></div>
              <div class="soft-card p-3 text-center"><div class="text-2xl font-black text-[#16254c]">24</div><div class="text-xs font-bold text-slate-500">Missions</div></div>
              <div class="soft-card p-3 text-center"><div class="text-2xl font-black text-[#2f4f9f]">20</div><div class="text-xs font-bold text-slate-500">Stamps</div></div>
            </div>
          </div>
        </div>
      </section>

      <section class="shell py-8">
        <div class="card p-6 md:p-8 text-center">
          <div class="text-sm font-black text-[#b22234] uppercase tracking-wide">Freedom 250 starts in</div>
          <div id="simpleCountdown" class="mt-3 text-3xl md:text-5xl font-black text-[#16254c]">Loading countdown...</div>
        </div>
      </section>

      <section id="mission" class="shell py-12">
        <div class="grid md:grid-cols-3 gap-5">
          <div class="card p-6 stat">
            <h2 class="text-2xl font-black text-[#16254c]">Mission</h2>
            <p class="mt-3 text-slate-600">Make the festival easy to navigate, measurable for organizers, and rewarding for every participant.</p>
          </div>
          <div class="card p-6 stat">
            <h2 class="text-2xl font-black text-[#16254c]">Organizers</h2>
            <p class="mt-3 text-slate-600">JKUAT hosts Freedom 250 with partner booths, volunteers, event admins, sponsors, and campus teams.</p>
          </div>
          <div class="card p-6 stat">
            <h2 class="text-2xl font-black text-[#16254c]">Platform</h2>
            <p class="mt-3 text-slate-600">A scalable event management system that can run Freedom 250 now and future events later.</p>
          </div>
        </div>
      </section>

      <section id="events" class="bg-white border-y border-slate-200 py-12">
        <div class="shell">
          <div class="flex items-end justify-between gap-4 mobile-stack">
            <div>
              <span class="pill">Event Zones</span>
              <h2 class="mt-3 text-3xl font-black text-[#16254c]">Scan, learn, compete, and redeem.</h2>
            </div>
            <button class="btn btn-secondary" id="viewParticipantDashboard"><i class="fa-solid fa-gauge-high"></i> Open Passport Dashboard</button>
          </div>
          <div id="zoneCards" class="grid md:grid-cols-4 gap-4 mt-7"></div>
        </div>
      </section>

      <section id="timeline" class="shell py-12">
        <div class="card p-6">
          <div class="flex items-center justify-between gap-4 mobile-stack">
            <div>
              <span class="pill">Timeline</span>
              <h2 class="mt-3 text-3xl font-black text-[#16254c]">Two-day festival flow</h2>
            </div>
            <button class="btn btn-outline" id="downloadScheduleBtn"><i class="fa-solid fa-file-arrow-down"></i> Export Schedule</button>
          </div>
          <div class="grid md:grid-cols-4 gap-4 mt-6">
            <div class="soft-card p-4"><div class="font-black text-[#b22234]">Day 1 | 9:00</div><p class="text-sm text-slate-600 mt-2">Registration, Liberty Pass activation, and orientation.</p></div>
            <div class="soft-card p-4"><div class="font-black text-[#b22234]">Day 1 | 11:00</div><p class="text-sm text-slate-600 mt-2">Zone missions, sponsor booths, demos, and leaderboard push.</p></div>
            <div class="soft-card p-4"><div class="font-black text-[#b22234]">Day 2 | 10:00</div><p class="text-sm text-slate-600 mt-2">Pitch sessions, townhall activities, and reward redemption.</p></div>
            <div class="soft-card p-4"><div class="font-black text-[#b22234]">Day 2 | 16:00</div><p class="text-sm text-slate-600 mt-2">Winners, analytics closeout, feedback, and export reports.</p></div>
          </div>
        </div>
      </section>
    </section>

    <section id="dashboardView" class="route-panel">
      <div class="shell py-8">
        <div class="flex items-center justify-between gap-4 mb-5 mobile-stack">
          <div>
            <span id="routeBadge" class="pill">Dashboard</span>
            <h1 id="dashboardTitle" class="mt-2 text-3xl font-black text-[#16254c]">Dashboard</h1>
          </div>
          <div class="flex gap-2 mobile-stack">
            <button class="btn btn-outline" data-route="/"><i class="fa-solid fa-house"></i> Public Site</button>
            <button class="btn btn-secondary" id="demoLoginBtn"><i class="fa-solid fa-user-check"></i> Demo Sign In</button>
          </div>
        </div>
        <div id="dashboardContent"></div>
      </div>
    </section>
  </main>

  <div id="toastContainer" class="fixed right-4 bottom-4 z-[100] grid gap-2 max-w-sm"></div>

  <div id="passModal" class="hidden fixed inset-0 z-[90] bg-slate-950/70 p-4 place-items-center">
    <div class="card w-full max-w-md p-6">
      <div class="flex justify-between items-start gap-4">
        <div>
          <h2 class="text-2xl font-black text-[#16254c]">Get Liberty Pass</h2>
          <p class="text-sm text-slate-600 mt-1">Default access is participant-only. Staff use their role URL.</p>
        </div>
        <button id="closePassModal" class="text-2xl text-slate-400 hover:text-slate-700" aria-label="Close">&times;</button>
      </div>
      <div class="grid gap-3 mt-5">
        <input id="participantName" placeholder="Full name" value="Alex Mwangi">
        <input id="participantEmail" placeholder="Email" value="alex@jkuat.ac.ke">
        <select id="participantType">
          <option>Student</option>
          <option>Faculty</option>
          <option>Visitor</option>
          <option>Sponsor</option>
        </select>
        <button id="createPassBtn" class="btn btn-primary"><i class="fa-solid fa-qrcode"></i> Create Liberty Pass</button>
      </div>
    </div>
  </div>

  <script>
    const eventDate = new Date(2026, 5, 11, 9, 0, 0);
    let currentRoute = "/";
    let participantDashboardOpen = false;
    let selectedBooth = "The Garage";
    let activeChart = null;

    const participant = {
      id: "FR250-001",
      name: "Alex Mwangi",
      type: "Student",
      coins: 2450,
      rank: 3,
      stamps: ["Garage Innovator", "Launchpad Leader", "Townhall Hero", "Arena Slam", "Culture Beat", "Taste of America"],
      missions: ["Visit three zones", "Vote in Townhall", "Submit event feedback"],
      notifications: ["VIP pass raffle is open", "New challenge at The Garage", "Redeem rewards before 4:00 PM"]
    };

    const staff = {
      volunteers: ["Maya Wanjiru", "Kevin Otieno", "Lorna Achieng", "Brian Kamau"],
      incidents: [
        { level: "Medium", location: "Taste of America", note: "Queue spillover near entrance" },
        { level: "Low", location: "The Arena", note: "Extra signage requested" }
      ],
      feedback: [
        { name: "Alex Mwangi", message: "The passport flow is clear and fun." },
        { name: "Zuri Achieng", message: "The Townhall booth needs more volunteers." }
      ],
      notifications: []
    };

    let booths = {
      "The Garage": { type: "Innovation", visitors: 342, leads: 87, scans: ["Alex Mwangi", "Zuri Achieng", "Brian Omondi"], traffic: 78, engagement: 92, reward: 50 },
      "The Launchpad": { type: "Entrepreneurship", visitors: 289, leads: 64, scans: ["Faith Kamau", "James Otieno"], traffic: 65, engagement: 88, reward: 50 },
      "The Townhall": { type: "Civic Engagement", visitors: 412, leads: 112, scans: ["Alex Mwangi", "Brian Omondi"], traffic: 92, engagement: 94, reward: 75 },
      "The Arena": { type: "Sports", visitors: 256, leads: 43, scans: [], traffic: 70, engagement: 76, reward: 50 },
      "Varsity Lounge": { type: "Education", visitors: 198, leads: 31, scans: [], traffic: 55, engagement: 72, reward: 40 },
      "Taste of America": { type: "Food and Culture", visitors: 523, leads: 89, scans: [], traffic: 88, engagement: 96, reward: 60 },
      "Culture Tent": { type: "Performance", visitors: 307, leads: 52, scans: [], traffic: 74, engagement: 84, reward: 50 },
      "Wellness Hub": { type: "Wellness", visitors: 167, leads: 28, scans: [], traffic: 48, engagement: 68, reward: 40 }
    };

    const attendance = { students: 2100, faculty: 347, visitors: 400, active: 1240, hourly: [450, 780, 1200, 1847, 2100, 2400, 2600, 2847] };

    function toast(message) {
      const item = document.createElement("div");
      item.className = "rounded-md bg-[#16254c] text-white shadow-xl px-4 py-3 text-sm font-semibold border-l-4 border-[#b22234]";
      item.innerHTML = `<i class="fa-solid fa-flag-usa mr-2"></i>${message}`;
      document.getElementById("toastContainer").appendChild(item);
      setTimeout(() => item.remove(), 3500);
    }

    function setRoute(path, push = true) {
      currentRoute = normalizeRoute(path);
      participantDashboardOpen = false;
      if (push && location.pathname !== currentRoute) pushRoute(currentRoute);
      renderRoute();
    }

    function pushRoute(path) {
      if (location.protocol === "file:") return;
      try {
        history.pushState({}, "", path);
      } catch (error) {
        console.warn("Route update skipped:", error);
      }
    }

    function normalizeRoute(path) {
      const clean = (path || "/").replace(/\/$/, "") || "/";
      if (["/admin", "/super-admin"].includes(clean)) return "/admin";
      if (["/volunteer", "/volunteers"].includes(clean)) return "/volunteer";
      if (["/booth-admin", "/booth", "/boothadmin"].includes(clean)) return "/booth-admin";
      if (["/organizer", "/event-organizer", "/event"].includes(clean)) return "/organizer";
      return "/";
    }

    function updateCountdown() {
      const diff = eventDate - new Date();
      const target = document.getElementById("simpleCountdown");
      if (!target) return;
      if (diff <= 0) {
        target.textContent = "Freedom 250 is live now";
        return;
      }
      const days = Math.floor(diff / 86400000);
      const hours = Math.floor((diff % 86400000) / 3600000);
      const mins = Math.floor((diff % 3600000) / 60000);
      target.textContent = `${days} Days. ${hours} Hours. ${mins} Min.`;
    }

    function renderRoute() {
      document.querySelectorAll(".route-panel").forEach(panel => panel.classList.remove("active"));
      document.querySelectorAll(".nav-link").forEach(link => link.classList.toggle("active", link.dataset.route === currentRoute));

      if (currentRoute === "/" && !participantDashboardOpen) {
        document.getElementById("participantView").classList.add("active");
        renderZones();
        updateCountdown();
        return;
      }

      document.getElementById("dashboardView").classList.add("active");
      if (participantDashboardOpen || currentRoute === "/") renderParticipantDashboard();
      if (currentRoute === "/booth-admin") renderBoothDashboard();
      if (currentRoute === "/volunteer") renderVolunteerDashboard();
      if (currentRoute === "/admin") renderAdminDashboard();
      if (currentRoute === "/organizer") renderOrganizerDashboard();
    }

    function renderZones() {
      const wrap = document.getElementById("zoneCards");
      wrap.innerHTML = Object.entries(booths).map(([name, booth]) => `
        <button class="card p-4 text-left hover:border-[#b22234] transition" data-zone="${name}">
          <div class="h-32 rounded-md bg-slate-100 border border-slate-200 grid place-items-center text-[#16254c]">
            <i class="fa-solid ${zoneIcon(booth.type)} text-4xl"></i>
          </div>
          <div class="mt-4 flex justify-between gap-3">
            <div>
              <h3 class="font-black text-[#16254c]">${name}</h3>
              <p class="text-sm text-slate-600">${booth.type}</p>
            </div>
            <span class="pill">+${booth.reward}</span>
          </div>
        </button>
      `).join("");
      wrap.querySelectorAll("[data-zone]").forEach(btn => {
        btn.addEventListener("click", () => openParticipantScan(btn.dataset.zone));
      });
    }

    function zoneIcon(type) {
      if (type.includes("Innovation")) return "fa-microchip";
      if (type.includes("Entrepreneurship")) return "fa-rocket";
      if (type.includes("Civic")) return "fa-landmark";
      if (type.includes("Sports")) return "fa-basketball";
      if (type.includes("Food")) return "fa-utensils";
      if (type.includes("Performance")) return "fa-music";
      if (type.includes("Wellness")) return "fa-heart-pulse";
      return "fa-building-columns";
    }

    function statCards(items) {
      return `<div class="grid md:grid-cols-4 gap-4">${items.map(item => `
        <div class="card p-5 stat">
          <div class="text-sm font-bold text-slate-500">${item.label}</div>
          <div class="mt-2 text-3xl font-black text-[#16254c]">${item.value}</div>
          <div class="mt-2 text-xs font-semibold text-slate-500">${item.note || ""}</div>
        </div>
      `).join("")}</div>`;
    }

    function renderParticipantDashboard() {
      document.getElementById("routeBadge").textContent = "Participant";
      document.getElementById("dashboardTitle").textContent = "My Liberty Pass";
      document.getElementById("dashboardContent").innerHTML = `
        ${statCards([
          { label: "Freedom Coins", value: participant.coins, note: "Redeem rewards" },
          { label: "Leaderboard Rank", value: "#" + participant.rank, note: "Top 5 participant" },
          { label: "Digital Stamps", value: participant.stamps.length + "/20", note: "Across all booths" },
          { label: "Active Missions", value: participant.missions.length, note: "Complete for bonus coins" }
        ])}
        <div class="grid dashboard-grid grid-cols-[1.2fr_.8fr] gap-5 mt-5">
          <div class="card p-6">
            <div class="flex items-center justify-between gap-3 mobile-stack">
              <h2 class="text-xl font-black text-[#16254c]">Booth Scanner</h2>
              <button class="btn btn-primary" id="participantQrBtn"><i class="fa-solid fa-qrcode"></i> Show My QR</button>
            </div>
            <div class="grid md:grid-cols-4 gap-3 mt-5">
              ${Object.entries(booths).map(([name, booth]) => `<button class="soft-card p-3 text-left scan-zone" data-zone="${name}"><div class="font-black text-[#16254c]">${name}</div><div class="text-xs text-slate-500 mt-1">+${booth.reward} coins</div></button>`).join("")}
            </div>
          </div>
          <div class="card p-6">
            <h2 class="text-xl font-black text-[#16254c]">Stamp Collection</h2>
            <div class="flex flex-wrap gap-2 mt-4">${participant.stamps.map(s => `<span class="pill"><i class="fa-solid fa-stamp text-[#b22234]"></i>${s}</span>`).join("")}</div>
          </div>
        </div>
        <div class="grid md:grid-cols-3 gap-5 mt-5">
          <div class="card p-6"><h3 class="font-black text-[#16254c]">Missions</h3><ul class="mt-3 grid gap-2 text-sm text-slate-600">${participant.missions.map(m => `<li><i class="fa-solid fa-circle-check text-[#2f4f9f] mr-2"></i>${m}</li>`).join("")}</ul><button id="completeMissionBtn" class="btn btn-secondary mt-5"><i class="fa-solid fa-check"></i> Complete Mission</button></div>
          <div class="card p-6"><h3 class="font-black text-[#16254c]">Rewards</h3><p class="text-sm text-slate-600 mt-3">Redeem coins for merch, priority seating, VIP raffle entries, and partner vouchers.</p><button id="redeemBtn" class="btn btn-outline mt-5"><i class="fa-solid fa-gift"></i> Redeem 500 Coins</button></div>
          <div class="card p-6"><h3 class="font-black text-[#16254c]">Feedback</h3><textarea id="feedbackText" rows="3" class="mt-3" placeholder="Share your event experience"></textarea><button id="feedbackBtn" class="btn btn-primary mt-3"><i class="fa-solid fa-paper-plane"></i> Submit Feedback</button></div>
        </div>
      `;
      document.querySelectorAll(".scan-zone").forEach(btn => btn.addEventListener("click", () => openParticipantScan(btn.dataset.zone)));
      document.getElementById("participantQrBtn").addEventListener("click", () => showQrModal("Participant QR", participant.id, "Booth admins scan this QR to award stamps and coins."));
      document.getElementById("completeMissionBtn").addEventListener("click", () => { participant.coins += 150; toast("Mission completed. 150 Freedom Coins added."); renderParticipantDashboard(); });
      document.getElementById("redeemBtn").addEventListener("click", () => {
        if (participant.coins >= 500) { participant.coins -= 500; toast("Reward redeemed. 500 coins deducted."); renderParticipantDashboard(); }
        else toast("Not enough coins for this reward.");
      });
      document.getElementById("feedbackBtn").addEventListener("click", () => {
        const text = document.getElementById("feedbackText").value.trim();
        if (!text) return toast("Add feedback before submitting.");
        staff.feedback.unshift({ name: participant.name, message: text });
        participant.coins += 25;
        toast("Feedback submitted. 25 Freedom Coins added.");
        renderParticipantDashboard();
      });
    }

    function renderBoothDashboard() {
      const booth = booths[selectedBooth] || booths[Object.keys(booths)[0]];
      document.getElementById("routeBadge").textContent = "/booth-admin";
      document.getElementById("dashboardTitle").textContent = "Booth Admin Dashboard";
      document.getElementById("dashboardContent").innerHTML = `
        <div class="card p-5 mb-5">
          <div class="grid md:grid-cols-[1fr_auto] gap-4 items-end">
            <div>
              <label class="text-sm font-black text-slate-600">Active booth</label>
              <select id="boothSelect" class="mt-2">${Object.keys(booths).map(name => `<option ${name === selectedBooth ? "selected" : ""}>${name}</option>`).join("")}</select>
            </div>
            <button class="btn btn-primary" id="scanParticipantBtn"><i class="fa-solid fa-camera"></i> Scan Participant QR</button>
          </div>
        </div>
        ${statCards([
          { label: "Visitors", value: booth.visitors, note: selectedBooth },
          { label: "Leads", value: booth.leads, note: "Captured contacts" },
          { label: "Traffic", value: booth.traffic + "%", note: "Current load" },
          { label: "Engagement", value: booth.engagement + "%", note: "Mission activity" }
        ])}
        <div class="grid dashboard-grid grid-cols-[1fr_1fr] gap-5 mt-5">
          <div class="card p-6">
            <h2 class="text-xl font-black text-[#16254c]">Recent QR Scans</h2>
            <div class="table-wrap mt-4">
              <table><tbody>${booth.scans.map(name => `<tr><td><i class="fa-solid fa-user-check text-[#2f4f9f] mr-2"></i>${name}</td><td>Verified</td><td>+${booth.reward} coins</td></tr>`).join("") || "<tr><td>No scans yet</td><td></td><td></td></tr>"}</tbody></table>
            </div>
          </div>
          <div class="card p-6">
            <h2 class="text-xl font-black text-[#16254c]">Booth Operations</h2>
            <div class="grid gap-3 mt-4">
              <button class="btn btn-secondary" id="leadBtn"><i class="fa-solid fa-id-card"></i> Capture Lead</button>
              <button class="btn btn-outline" id="challengeBtn"><i class="fa-solid fa-bullseye"></i> Launch Booth Challenge</button>
              <button class="btn btn-outline" id="broadcastBoothBtn"><i class="fa-solid fa-bullhorn"></i> Send Booth Broadcast</button>
              <button class="btn btn-outline" id="inventoryBtn"><i class="fa-solid fa-boxes-stacked"></i> Update Rewards Inventory</button>
            </div>
          </div>
        </div>
      `;
      document.getElementById("boothSelect").addEventListener("change", e => { selectedBooth = e.target.value; renderBoothDashboard(); });
      document.getElementById("scanParticipantBtn").addEventListener("click", () => scanParticipantAtBooth());
      document.getElementById("leadBtn").addEventListener("click", () => { booth.leads += 1; toast("Lead captured for " + selectedBooth + "."); renderBoothDashboard(); });
      document.getElementById("challengeBtn").addEventListener("click", () => toast("Booth challenge launched for " + selectedBooth + "."));
      document.getElementById("broadcastBoothBtn").addEventListener("click", () => toast("Broadcast sent to participants near " + selectedBooth + "."));
      document.getElementById("inventoryBtn").addEventListener("click", () => toast("Rewards inventory marked as updated."));
    }

    function renderVolunteerDashboard() {
      document.getElementById("routeBadge").textContent = "/volunteer";
      document.getElementById("dashboardTitle").textContent = "Volunteer Command Center";
      document.getElementById("dashboardContent").innerHTML = `
        ${statCards([
          { label: "Total Check-ins", value: attendance.students + attendance.faculty + attendance.visitors, note: "All entrances" },
          { label: "Currently Active", value: attendance.active, note: "Live inside venue" },
          { label: "Open Incidents", value: staff.incidents.length, note: "Needs attention" },
          { label: "Assigned Volunteers", value: staff.volunteers.length, note: "On shift" }
        ])}
        <div class="grid dashboard-grid grid-cols-[1fr_1fr] gap-5 mt-5">
          <div class="card p-6">
            <h2 class="text-xl font-black text-[#16254c]">Check-in Station</h2>
            <div class="grid md:grid-cols-2 gap-3 mt-4">
              <button class="btn btn-primary" id="volScanBtn"><i class="fa-solid fa-camera"></i> Scan Entry QR</button>
              <button class="btn btn-outline" id="manualEntryBtn"><i class="fa-solid fa-keyboard"></i> Manual Check-in</button>
            </div>
            <div class="mt-5 grid gap-2 text-sm text-slate-600">
              <div class="soft-card p-3">Students: <strong>${attendance.students}</strong></div>
              <div class="soft-card p-3">Faculty: <strong>${attendance.faculty}</strong></div>
              <div class="soft-card p-3">Visitors: <strong>${attendance.visitors}</strong></div>
            </div>
          </div>
          <div class="card p-6">
            <h2 class="text-xl font-black text-[#16254c]">Incident Reporting</h2>
            <select id="incidentLevel" class="mt-4"><option>Low</option><option>Medium</option><option>High</option></select>
            <input id="incidentLocation" class="mt-3" placeholder="Location">
            <textarea id="incidentNote" class="mt-3" rows="3" placeholder="Describe the issue"></textarea>
            <button class="btn btn-primary mt-3" id="incidentBtn"><i class="fa-solid fa-triangle-exclamation"></i> Submit Incident</button>
          </div>
        </div>
        <div class="card p-6 mt-5">
          <h2 class="text-xl font-black text-[#16254c]">Volunteer Assignments</h2>
          <div class="grid md:grid-cols-4 gap-3 mt-4">${staff.volunteers.map((name, index) => `<div class="soft-card p-3"><div class="font-black">${name}</div><div class="text-sm text-slate-500">${Object.keys(booths)[index % Object.keys(booths).length]}</div></div>`).join("")}</div>
        </div>
      `;
      document.getElementById("volScanBtn").addEventListener("click", () => { attendance.active += 1; toast("Entry QR verified."); renderVolunteerDashboard(); });
      document.getElementById("manualEntryBtn").addEventListener("click", () => { attendance.visitors += 1; attendance.active += 1; toast("Manual check-in recorded."); renderVolunteerDashboard(); });
      document.getElementById("incidentBtn").addEventListener("click", () => {
        const note = document.getElementById("incidentNote").value.trim();
        const location = document.getElementById("incidentLocation").value.trim() || "Unspecified";
        if (!note) return toast("Add incident details before submitting.");
        staff.incidents.unshift({ level: document.getElementById("incidentLevel").value, location, note });
        toast("Incident submitted to super admin.");
        renderVolunteerDashboard();
      });
    }

    function renderAdminDashboard() {
      document.getElementById("routeBadge").textContent = "/admin";
      document.getElementById("dashboardTitle").textContent = "Super Admin Dashboard";
      document.getElementById("dashboardContent").innerHTML = `
        ${statCards([
          { label: "Total Attendance", value: attendance.students + attendance.faculty + attendance.visitors, note: "Registered and checked in" },
          { label: "Active Users", value: attendance.active, note: "Live session estimate" },
          { label: "Booths", value: Object.keys(booths).length, note: "Can create missing booths" },
          { label: "Open Incidents", value: staff.incidents.length, note: "Volunteer reports" }
        ])}
        <div class="grid dashboard-grid grid-cols-[1fr_1fr] gap-5 mt-5">
          <div class="card p-6">
            <h2 class="text-xl font-black text-[#16254c]">Create Missing Booth</h2>
            <div class="grid md:grid-cols-2 gap-3 mt-4">
              <input id="newBoothName" placeholder="Booth name">
              <input id="newBoothType" placeholder="Booth category">
              <input id="newBoothReward" type="number" placeholder="Coin reward" value="50">
              <button class="btn btn-primary" id="createBoothBtn"><i class="fa-solid fa-plus"></i> Create Booth</button>
            </div>
          </div>
          <div class="card p-6">
            <h2 class="text-xl font-black text-[#16254c]">Global Controls</h2>
            <div class="grid gap-3 mt-4">
              <button class="btn btn-secondary" id="globalBroadcastBtn"><i class="fa-solid fa-bullhorn"></i> Send Global Broadcast</button>
              <button class="btn btn-outline" id="exportAdminBtn"><i class="fa-solid fa-file-csv"></i> Export Attendance CSV</button>
              <button class="btn btn-outline" id="syncSystemBtn"><i class="fa-solid fa-rotate"></i> Sync Offline Scans</button>
            </div>
          </div>
        </div>
        <div class="grid dashboard-grid grid-cols-[1fr_1fr] gap-5 mt-5">
          <div class="card p-6">
            <h2 class="text-xl font-black text-[#16254c]">Booth Performance</h2>
            <canvas id="adminChart" height="180" class="mt-4"></canvas>
          </div>
          <div class="card p-6">
            <h2 class="text-xl font-black text-[#16254c]">Incidents and Feedback</h2>
            <div class="grid gap-3 mt-4 text-sm">
              ${staff.incidents.map(i => `<div class="soft-card p-3"><strong>${i.level}</strong> | ${i.location}<div class="text-slate-600">${i.note}</div></div>`).join("")}
              ${staff.feedback.slice(0, 3).map(f => `<div class="soft-card p-3"><strong>${f.name}</strong><div class="text-slate-600">${f.message}</div></div>`).join("")}
            </div>
          </div>
        </div>
        <div class="card p-6 mt-5">
          <h2 class="text-xl font-black text-[#16254c]">Booth Registry</h2>
          <div class="table-wrap mt-4">
            <table><thead><tr><th>Booth</th><th>Category</th><th>Visitors</th><th>Leads</th><th>Reward</th></tr></thead><tbody>${Object.entries(booths).map(([name, b]) => `<tr><td>${name}</td><td>${b.type}</td><td>${b.visitors}</td><td>${b.leads}</td><td>${b.reward}</td></tr>`).join("")}</tbody></table>
          </div>
        </div>
      `;
      document.getElementById("createBoothBtn").addEventListener("click", createBooth);
      document.getElementById("globalBroadcastBtn").addEventListener("click", () => toast("Global broadcast sent to participants, volunteers, and booth admins."));
      document.getElementById("exportAdminBtn").addEventListener("click", () => exportCsv("freedom-250-attendance.csv", [["Metric", "Value"], ["Students", attendance.students], ["Faculty", attendance.faculty], ["Visitors", attendance.visitors], ["Active", attendance.active]]));
      document.getElementById("syncSystemBtn").addEventListener("click", () => toast("Offline scans synced."));
      renderAdminChart();
    }

    function renderOrganizerDashboard() {
      document.getElementById("routeBadge").textContent = "/organizer";
      document.getElementById("dashboardTitle").textContent = "Event Organizer Dashboard";
      document.getElementById("dashboardContent").innerHTML = `
        ${statCards([
          { label: "Program Items", value: 18, note: "Sessions and activations" },
          { label: "Sponsors", value: 12, note: "Partner organizations" },
          { label: "Reward Claims", value: 318, note: "Across all booths" },
          { label: "Satisfaction", value: "91%", note: "Feedback average" }
        ])}
        <div class="grid md:grid-cols-3 gap-5 mt-5">
          <div class="card p-6"><h2 class="text-xl font-black text-[#16254c]">Program Schedule</h2><p class="text-sm text-slate-600 mt-3">Manage stage blocks, speaker sessions, and sponsor activations.</p><button class="btn btn-outline mt-5"><i class="fa-solid fa-calendar-plus"></i> Add Program Item</button></div>
          <div class="card p-6"><h2 class="text-xl font-black text-[#16254c]">Sponsor Delivery</h2><p class="text-sm text-slate-600 mt-3">Track leads, booth scans, campaign messages, and sponsor ROI.</p><button class="btn btn-outline mt-5"><i class="fa-solid fa-handshake"></i> Sponsor Report</button></div>
          <div class="card p-6"><h2 class="text-xl font-black text-[#16254c]">Content Moderation</h2><p class="text-sm text-slate-600 mt-3">Review feedback, announcements, missions, and reward copy.</p><button class="btn btn-outline mt-5"><i class="fa-solid fa-shield-halved"></i> Review Queue</button></div>
        </div>
      `;
    }

    function renderAdminChart() {
      const canvas = document.getElementById("adminChart");
      if (!canvas || !window.Chart) return;
      if (activeChart) activeChart.destroy();
      activeChart = new Chart(canvas, {
        type: "bar",
        data: {
          labels: Object.keys(booths),
          datasets: [{
            label: "Visitors",
            data: Object.values(booths).map(b => b.visitors),
            backgroundColor: "#b22234"
          }]
        },
        options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
      });
    }

    function createBooth() {
      const name = document.getElementById("newBoothName").value.trim();
      const type = document.getElementById("newBoothType").value.trim() || "General";
      const reward = Number(document.getElementById("newBoothReward").value || 50);
      if (!name) return toast("Enter a booth name.");
      if (booths[name]) return toast("That booth already exists.");
      booths[name] = { type, visitors: 0, leads: 0, scans: [], traffic: 0, engagement: 0, reward };
      selectedBooth = name;
      toast(name + " created and added to the booth registry.");
      renderAdminDashboard();
    }

    function scanParticipantAtBooth() {
      const booth = booths[selectedBooth];
      const name = prompt("Participant name or QR ID", participant.name);
      if (!name) return;
      if (!booth.scans.includes(name)) booth.scans.unshift(name);
      booth.visitors += 1;
      booth.leads += 1;
      booth.traffic = Math.min(100, booth.traffic + 2);
      if (name === participant.name || name === participant.id) {
        participant.coins += booth.reward;
        const stamp = selectedBooth + " Verified Stamp";
        if (!participant.stamps.includes(stamp)) participant.stamps.unshift(stamp);
      }
      toast("Participant QR scanned at " + selectedBooth + ".");
      renderBoothDashboard();
    }

    function openParticipantScan(zone) {
      if (!participantDashboardOpen) {
        toast("Liberty Pass opened. Simulate scans from the participant dashboard.");
        participantDashboardOpen = true;
        pushRoute("/");
        renderRoute();
        setTimeout(() => openParticipantScan(zone), 100);
        return;
      }
      const booth = booths[zone];
      if (!booth) return;
      if (!participant.stamps.includes(zone + " Explorer Stamp")) participant.stamps.unshift(zone + " Explorer Stamp");
      participant.coins += booth.reward;
      booth.visitors += 1;
      if (!booth.scans.includes(participant.name)) booth.scans.unshift(participant.name);
      toast("Scanned " + zone + ". " + booth.reward + " Freedom Coins added.");
      renderParticipantDashboard();
    }

    function showQrModal(title, code, note) {
      const modal = document.createElement("div");
      modal.className = "fixed inset-0 z-[95] bg-slate-950/70 p-4 grid place-items-center";
      modal.innerHTML = `
        <div class="card p-6 max-w-sm w-full text-center">
          <h2 class="text-2xl font-black text-[#16254c]">${title}</h2>
          <div class="my-5 mx-auto h-40 w-40 bg-white border-8 border-slate-100 grid place-items-center text-[#16254c]">
            <i class="fa-solid fa-qrcode text-8xl"></i>
          </div>
          <div class="font-black">${code}</div>
          <p class="text-sm text-slate-600 mt-2">${note}</p>
          <button class="btn btn-primary mt-5 w-full" id="closeQr"><i class="fa-solid fa-check"></i> Done</button>
        </div>
      `;
      document.body.appendChild(modal);
      modal.querySelector("#closeQr").addEventListener("click", () => modal.remove());
    }

    function exportCsv(fileName, rows) {
      const csv = rows.map(row => row.map(cell => `"${String(cell).replaceAll('"', '""')}"`).join(",")).join("\n");
      const blob = new Blob([csv], { type: "text/csv" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = fileName;
      a.click();
      URL.revokeObjectURL(url);
      toast("CSV export prepared.");
    }

    document.querySelectorAll("[data-route]").forEach(btn => btn.addEventListener("click", () => setRoute(btn.dataset.route)));
    document.getElementById("menuBtn").addEventListener("click", () => document.getElementById("mobileMenu").classList.toggle("open"));
    document.getElementById("openPassBtn").addEventListener("click", () => document.getElementById("passModal").classList.remove("hidden"));
    document.getElementById("closePassModal").addEventListener("click", () => document.getElementById("passModal").classList.add("hidden"));
    document.getElementById("createPassBtn").addEventListener("click", () => {
      participant.name = document.getElementById("participantName").value.trim() || "Participant";
      participant.type = document.getElementById("participantType").value;
      document.getElementById("passModal").classList.add("hidden");
      participantDashboardOpen = true;
      toast("Liberty Pass created for " + participant.name + ".");
      renderRoute();
    });
    document.getElementById("viewParticipantDashboard").addEventListener("click", () => { participantDashboardOpen = true; renderRoute(); });
    document.getElementById("demoLoginBtn").addEventListener("click", () => toast("Demo role session active for " + currentRoute + "."));
    document.getElementById("downloadScheduleBtn").addEventListener("click", () => exportCsv("freedom-250-schedule.csv", [["Time", "Program"], ["Day 1 9:00", "Registration"], ["Day 1 11:00", "Zone missions"], ["Day 2 10:00", "Pitch sessions"], ["Day 2 16:00", "Winners"]]));
    window.addEventListener("popstate", () => { currentRoute = normalizeRoute(location.pathname); participantDashboardOpen = false; renderRoute(); });

    currentRoute = normalizeRoute(location.pathname);
    renderRoute();
    updateCountdown();
    setInterval(updateCountdown, 60000);
  </script>
</body>
</html>
