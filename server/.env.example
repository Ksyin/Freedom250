## Copy to .env and fill in the values
# SendGrid API Key
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY

# Firebase Admin service account JSON (OPTION 1): put the JSON here as a single-line string
# or set GOOGLE_APPLICATION_CREDENTIALS to point to a service account JSON file (OPTION 2)
# FIREBASE_SERVICE_ACCOUNT_JSON={...}
# or
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Optional: origin allowed for CORS when testing locally
ALLOWED_ORIGIN=http://localhost:8000

# Port for the example server
PORT=3000

# Default from email (used by SendGrid)
DEFAULT_FROM_EMAIL=events@freedom250.org

# Admin email to receive assistant/contact messages
ADMIN_EMAIL=organizer@freedom250.org
